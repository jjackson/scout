# Kamal parses this file with Ruby's Dotenv — only VAR=value and VAR=$(cmd) work.
# All fetch logic lives in scripts/resolve-secrets.sh which caches AWS calls.
# For local deploys:
#   ./scripts/fetch-deploy-env.sh   # one-time: generates .env.deploy
#   source .env.deploy              # each shell session before running kamal

DATABASE_URL=$(scripts/resolve-secrets.sh DATABASE_URL)
MANAGED_DATABASE_URL=$(scripts/resolve-secrets.sh MANAGED_DATABASE_URL)
DJANGO_SECRET_KEY=$(scripts/resolve-secrets.sh DJANGO_SECRET_KEY)
DB_CREDENTIAL_KEY=$(scripts/resolve-secrets.sh DB_CREDENTIAL_KEY)
ANTHROPIC_API_KEY=$(scripts/resolve-secrets.sh ANTHROPIC_API_KEY)
